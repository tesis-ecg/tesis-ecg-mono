# Dev-only image for the Vite frontend with hot-module reload.
# Production builds are handled elsewhere (e.g. Vercel) — this is for `docker compose` local dev.
FROM node:22-alpine

WORKDIR /app

# Install deps against the lockfile. The `prepare` script wires up husky git hooks
# (`cd .. && git config ...`), which has no meaning inside the container and would fail,
# so we drop it before installing. esbuild/rollup native binaries are still built normally.
COPY package.json package-lock.json ./
RUN npm pkg delete scripts.prepare && npm ci

# Source is bind-mounted at runtime (see docker-compose.yml); nothing else to copy.
EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
