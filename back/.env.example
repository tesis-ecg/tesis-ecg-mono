DATABASE_URL=postgresql+asyncpg://holter:holter@localhost:5435/holter
FRONTEND_URL=http://localhost:5173
S3_BUCKET_NAME=ecg-batches
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
ENVIRONMENT=development

# Auth0 (ROPG + Management API)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://api.holter.local
AUTH0_MGMT_CLIENT_ID=your-mgmt-client-id
AUTH0_MGMT_CLIENT_SECRET=your-mgmt-client-secret
AUTH0_CONNECTION=Username-Password-Authentication

# Session JWT (our own secret — never commit the real value)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
